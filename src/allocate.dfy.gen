  var result: seq<int> := [];
  var p := 0;
  while (p < n)
    invariant (0 <= p)
    invariant (p <= n)
    invariant (|result| == p)
    invariant forall k: int :: ((0 <= k) ==> (k < p) ==> (result[k] == (a[k] + b[k])))
    invariant (sumTo(result, p) == (sumTo(a, p) + sumTo(b, p)))
    decreases (n - p)
  {
    result := (result + [(a[p] + b[p])]);
    p := (p + 1);
  }
  return result;
}

