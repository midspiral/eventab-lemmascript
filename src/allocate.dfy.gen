    invariant (p <= n)
    invariant (|result| == p)
    invariant forall k: int :: ((0 <= k) ==> (k < p) ==> (result[k] == (paid[k] - owed[k])))
    invariant (sumTo(result, p) == (sumTo(paid, p) - sumTo(owed, p)))
